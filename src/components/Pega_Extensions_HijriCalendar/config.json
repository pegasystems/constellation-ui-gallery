      "label": "Field label",
      "format": "TEXT",
      "required": true
    },
    {
      "name": "value",
      "label": "Value",
      "format": "TEXT"
    },
    {
      "name": "readOnly",
      "label": "Edit mode",
      "format": "READONLY"
    },
    {
      "label": "Input settings",
      "format": "GROUP",
      "visibility": "(!readOnly = true)",
      "properties": [
        {
          "name": "storeAsHijri",
