{
  "name": "Org_Library_HijriCalendar",
  "label": "Hijri Calendar",
  "description": "A field component to display and pick Hijri dates",
  "organization": "Pega",
  "version": "4.0.1",
  "library": "Extensions",
  "allowedApplications": [],
  "componentKey": "Org_Library_HijriCalendar",
  "type": "Field",
  "subtype": "Date",
  "icon": "images/pz-date-time-active.svg",
