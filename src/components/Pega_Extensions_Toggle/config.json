        {
            "name": "hideLabel",
            "label": "Hide Label",
            "format": "BOOLEAN",
            "visibility": "$this.label IS_NULL",
            "defaultValue": true
        },
        {
            "name": "hideLabel",
            "label": "Hide Label",
            "format": "BOOLEAN",
            "visibility": "$this.label IS_NOT_NULL",
            "defaultValue": false
        },
        {
            "name": "readOnly",
            "label": "Edit mode",
            "format": "READONLY"
        },
        {
