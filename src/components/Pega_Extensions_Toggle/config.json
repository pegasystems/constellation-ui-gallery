                {
                    "name": "caption",
                    "format": "FIELDLABELINPUT",
                    "visibility": "@ISINEMBEDDEDDATAMULTI == true"
                },
                {
                    "name": "helperText",
                    "label": "Helper text",
                    "format": "TEXT"
                },
                {
                    "format": "DEFAULTVALUE",
                    "visibility": "@RULEVIEWTYPE == 'search'"
                }
            ]
        },
        {
            "label": "Read-only settings",
            "format": "GROUP",
            "properties": [
