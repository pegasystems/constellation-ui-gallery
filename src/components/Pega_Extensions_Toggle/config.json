                    },
                    "source": [
                        {
                            "key": "Yes/No",
                            "value": "Yes/No"
                        },
                        {
                            "key": "True/False",
                            "value": "True/False"
                        }
                    ]
                }
            ]
        },
        {
            "label": "Conditions",
            "format": "GROUP",
            "properties": [
                {
                    "name": "required",
                    "label": "Required",
                    "format": "REQUIRED",
                    "visibility": "!($this.readOnly == true) && (@VIEWTEMPLATESUBTYPE == 'FORM' || @ISINEMBEDDEDDATAMULTI == true || @RULEVIEWTYPE == 'search')"
                },
                {
                    "name": "disabled",
                    "label": "Disabled",
                    "format": "DISABLED",
                    "visibility": "!($this.readOnly == true) && (@VIEWTEMPLATESUBTYPE == 'FORM' || @ISINEMBEDDEDDATAMULTI == true || @RULEVIEWTYPE == 'search')"
                },
                {
                    "name": "visibility",
                    "label": "Visibility",
                    "format": "VISIBILITY"
