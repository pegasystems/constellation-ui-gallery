        },
        {
            "label": "Column settings",
            "format": "GROUP",
            "visibility": "@ISINEMBEDDEDDATAMULTI == true",
            "properties": [
                {
                    "name": "columnWidth",
                    "label": "Column width",
                    "format": "SELECT",
                    "source": [
                        {
                            "key": "auto",
                            "value": "Auto"
                        },
                        {
                            "key": "custom",
                            "value": "Custom"
                        }
                    ]
                },
                {
                    "name": "width",
                    "label": "Width (px)",
                    "format": "NUMBER",
                    "visibility": "$this.columnWidth == 'custom'"
                }
            ]
        },
        {
            "label": "Input settings",
            "format": "GROUP",
